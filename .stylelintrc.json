{
  "extends": ["stylelint-config-standard"],
  "rules": {
      "function-no-unknown": [
        true,
        {
          "ignoreFunctions": ["-moz-pref"]
        }
      ],
      "media-feature-name-no-unknown": [
        true,
        {
          "ignoreMediaFeatureNames": ["-moz-pref"]
        }
      ]
    }
}
