{
  "name": "arc-theme",
  "private": true,
  "scripts": {
    "lint": "bun lint:pretty && stylelint \"**/*.{ts,tsx,js,jsx,json,css}\"",
    "lint:fix": "bun pretty && stylelint --fix \"**/*.{ts,tsx,js,jsx,json,css}\"",
    "lint:pretty": "prettier --check \"**/*.{ts,tsx,js,jsx,json,css}\"",
    "pretty": "prettier --write \"**/*.{ts,tsx,js,jsx,json,css}\"",
    "prepare": "husky"
  },
  "dependencies": {
    "husky": "^9.1.7",
    "prettier": "3.8.3",
    "stylelint": "^17.9.0",
    "stylelint-config-standard": "^40.0.0"
  }
}